#!/usr/bin/env bash
set -e

staged=$(git diff --cached --name-only --diff-filter=ACMR)

# yamllint on staged YAML files
staged_yaml=$(echo "$staged" | grep -E '\.(yml|yaml)$' || true)
if [ -n "$staged_yaml" ]; then
  if command -v yamllint &>/dev/null; then
    echo "[pre-commit] yamllint..."
    echo "$staged_yaml" | xargs yamllint -c .yamllint
  else
    echo "[pre-commit] WARNING: yamllint not installed, skipping YAML lint."
  fi
fi

# ansible-lint on staged ansible files
staged_ansible=$(echo "$staged" | grep -E '^ansible/' || true)
if [ -n "$staged_ansible" ]; then
  if command -v ansible-lint &>/dev/null; then
    echo "[pre-commit] ansible-lint..."
    ansible-lint $staged_ansible
  else
    echo "[pre-commit] WARNING: ansible-lint not installed, skipping."
  fi
fi

# detect secrets / private keys
if echo "$staged" | xargs grep -l -E 'PRIVATE KEY|BEGIN RSA|password\s*=\s*\S' 2>/dev/null | grep -qv '\.example$'; then
  echo "[pre-commit] ERROR: Possible secret or private key detected in staged files."
  echo "             Use .env.example for templates; never commit credentials."
  exit 1
fi
